## .gitignore for ASP.NET / .NET projects
## Covers Visual Studio, Rider/JetBrains, VS Code, and common tooling.

# ---------- Build results ----------
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Oo]ut/
artifacts/

# ---------- .NET / Roslyn ----------
project.lock.json
project.fragment.lock.json
*.binlog
*.nupkg
*.snupkg
*.pdb
*.dll
*.exe
*.cache
*.VisualState.xml

# ---------- ASP.NET specific ----------
# User secrets are stored outside the project, but ignore just in case
**/secrets.json
**/appsettings.*.Local.json
**/appsettings.Development.json
ScaffoldingReadMe.txt

# Published/publish output
[Pp]ublish/
[Pp]ublishProfiles/
PublishScripts/
*.[Pp]ublish.xml
*.pubxml
*.pubxml.user
*.publishproj
*.azurePubxml

# wwwroot build artifacts (keep the folder, ignore generated output)
wwwroot/dist/
wwwroot/lib/

# ---------- Node / frontend (SPA templates) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*

# ---------- User-specific files ----------
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
mono_crash.*

# ---------- Visual Studio ----------
.vs/
*.VC.db
*.VC.VC.opendb
*.opensdf
*.sdf
*.psess
*.vsp
*.vspx
*.sap
*.svclog
StyleCopReport.xml
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
$tf/

# ---------- JetBrains Rider / ReSharper ----------
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.DotCover

# ---------- VS Code ----------
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---------- Test results / coverage ----------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
nunit-*.xml
coverage*.json
coverage*.xml
coverage*.info
CodeCoverage/
*.coverage
*.coveragexml

# ---------- EF / Database ----------
*.mdf
*.ldf
*.ndf
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# ---------- Docker / misc ----------
*.env
.env.local
.env.*.local
docker-compose.override.yml

# ---------- OS junk ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
~$*
*~
*.bak
*.tmp
